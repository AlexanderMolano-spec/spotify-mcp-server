# HTTP server
PORT=11070
HOST=0.0.0.0

# Spotify OAuth application
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:11070/auth/callback

# Local single-user token storage. Do not commit the token file.
SPOTIFY_TOKEN_STORE_PATH=.spotify-token.json

# Comma-separated scope list used by the local OAuth flow.
SPOTIFY_SCOPES=user-read-private,user-read-email,user-read-playback-state,user-read-currently-playing,user-modify-playback-state,playlist-read-private,playlist-read-collaborative
